{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "db-designer",
  "version": "0.2.1",
  "identifier": "com.dcp.db-designer",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "db-designer",
        "width": 1200,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwRDgyN0M1QUZFN0FEOUIKUldTYnJlZXZ4U2ZZUUxJVmRKbDZPdTNha1FvOEQ5MVVGMjBTbXQvOCtFUUM3QXgrdVBLZ1VXWmgK",
      "endpoints": [
        "https://github.com/dddcp/db-designer/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
